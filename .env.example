# --- Discord Integration ---
# Dein Discord Webhook URL für Logs und Alerts
VITE_DISCORD_WEBHOOK_URL=

# --- Google Analytics 4 ---
# Die Mess-ID von Google Analytics (z.B. G-NSVNDGX1WL)
