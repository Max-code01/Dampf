# --- Discord Integration (Config in AI Studio Settings -> Secrets) ---

# 1. Sicherheits-Logs (Login/Logout/Fehler)
# Webhook URL für den Kanal, in dem die System-Logs erscheinen sollen.
VITE_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1477344178290556968/uOsLf-w0Jbl3uldMuSlCUODdaWufFiNORVHOLiYeXLmiDf74Rgdh4WZb93De_wV_--Bf

# 2. Status-Widget (Spieleranzahl-Anzeige)
# Erstelle einen NEUEN Webhook in einem anderen Discord-Kanal für die Status-Updates.
# Füge diesen Link in den AI Studio Settings unter VITE_DISCORD_STATUS_WEBHOOK ein.
VITE_DISCORD_STATUS_WEBHOOK=

# 3. Discord Server ID
# Die ID deines Discord-Servers (Rechtsklick auf Server-Icon -> ID kopieren).
VITE_DISCORD_GUILD_ID=1451980583969230882


# --- Discord OAuth Login (Setup in Firebase & Discord Developer Portal) ---

# A. IM DISCORD DEVELOPER PORTAL (https://discord.com/developers/applications):
# 1. 'OAuth2' -> 'Redirects' -> 'Add Redirect' klicken.
# 2. URI einfügen: https://gen-lang-client-0215562127.firebaseapp.com/__/auth/handler
# 3. 'Save Changes' (ganz unten) klicken!

# B. IN DER FIREBASE CONSOLE (Authentication):
# 1. Gehe zu 'Authentication' -> 'Settings'.
# 2. Klicke auf 'Identity Platform aktivieren' (falls nötig, damit 'OAuth' erscheint).
# 3. Gehe zu 'Sign-in method' -> 'Add new provider'.
# 4. Wähle 'OAuth' (Benutzerdefiniert).
# 5. Anbieter-ID: discord.com
# 6. Client-ID: 1503393592004317395
# 7. Client-Secret: Od3rnVIpAyEeRdyFz6ZJqvSe_SDn3XaG

# C. FALLS NUR 'OpenID Connect' (OIDC) verfügbar ist:
# 1. In Firebase: Anbieter-ID (z.B. oidc.discord-1LEXA) kopieren.
# 2. In AI Studio Settings -> Secrets als VITE_DISCORD_PROVIDER_ID speichern!
VITE_DISCORD_PROVIDER_ID=oidc.discord-1LEXA
# 3. Aussteller (URL): https://discord.com
# 4. Client-ID: 1503393592004317395
# 5. Client-Secret: Od3rnVIpAyEeRdyFz6ZJqvSe_SDn3XaG
# 6. Scopes: openid, email, profile (für OIDC)

# D. IN AI STUDIO SETTINGS -> SECRETS:
DISCORD_CLIENT_ID=1503393592004317395
DISCORD_CLIENT_SECRET=Od3rnVIpAyEeRdyFz6ZJqvSe_SDn3XaG
VITE_DISCORD_REDIRECT_URI=https://gen-lang-client-0215562127.firebaseapp.com/__/auth/handler

# --- Google Analytics 4 ---
# Die Mess-ID von Google Analytics (z.B. G-NSVNDGX1WL)
VITE_GA_MEASUREMENT_ID=

# --- Umami Analytics (Datenschutzfreundliche Alternative) ---
# Die Website ID von Umami
VITE_UMAMI_ID=
# Der Link zum Umami Script (z.B. https://cloud.umami.is/script.js)
VITE_UMAMI_SRC=
