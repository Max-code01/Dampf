rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'max.schule13@gmail.com' ||
        request.auth.token.email == 'max@community.local' ||
        request.auth.token.email == 'dampf@community.local' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // ChatMessage Validation
    function isValidChatMessage(data) {
      return data.keys().hasAll(['text', 'userId', 'displayName', 'createdAt']) &&
             (data.keys().size() == 4 || (data.keys().size() == 5 && data.role is string)) &&
             data.text is string && data.text.size() <= 500 &&
             data.userId == request.auth.uid &&
             data.displayName is string &&
             data.createdAt == request.time;
    }

    // Player Validation
    function isValidPlayer(data) {
      return data.keys().hasAll(['username', 'server', 'lastSeen']) &&
             data.keys().size() == 3 &&
             data.username is string && data.username.size() <= 16 &&
             data.server in ['pvp', 'survival'] &&
             data.lastSeen is string;
    }

    // ServerStatus Validation
    function isValidServerStatus(data) {
      return data.keys().hasAll(['online', 'playerCount', 'maxPlayers']) &&
             data.keys().size() == 3 &&
             data.online is bool &&
             data.playerCount is int &&
             data.maxPlayers is int;
    }

    // UserProfile Validation
    function isValidUserProfile(data, docId) {
      return data.keys().hasAll(['displayName', 'minecraftUsername', 'isOnline', 'currentServer', 'updatedAt', 'userId']) &&
             (data.keys().size() >= 6 && data.keys().size() <= 8) &&
             data.displayName is string && data.displayName.size() <= 32 &&
             data.minecraftUsername is string && data.minecraftUsername.size() <= 16 &&
             data.isOnline is bool &&
             data.currentServer in ['none', 'pvp', 'survival'] &&
             // Ensure nobody can set themselves as Admin unless they are already Admin
             (!data.keys().hasAll(['role']) || data.role != 'Admin' || isAdmin()) &&
             data.updatedAt is timestamp &&
             data.userId == docId;
    }

    // User Profiles Collection
    match /user_profiles/{userId} {
      allow read: if true;
      allow create, update: if isSignedIn() && (userId == request.auth.uid || isAdmin()) && isValidUserProfile(incoming(), userId);
      allow delete: if isAdmin();
    }

    // Online Players Collection
    match /online_players/{playerId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(playerId) && isValidPlayer(incoming());
      allow delete: if isAdmin();
    }

    // Server Status Collection
    match /server_status/{serverId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(serverId) && isValidServerStatus(incoming());
    }

    // Chat Messages
    match /chat_messages/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidChatMessage(incoming());
      allow delete: if isAdmin();
    }

    // App Config
    match /app_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
